# EDEN OS V2 — Environment Variables
# Copy this file to .env and fill in your real keys

# xAI / Grok API Key (for Eve voice + brain)
XAI_API_KEY=your-xai-api-key-here

# Hugging Face Token (for model downloads)
HF_TOKEN=your-hf-token-here

# Anthropic API Key (fallback, optional)
ANTHROPIC_API_KEY=

# Models path on Seagate 5TB
MODELS_PATH=D:/eden-models

# RunPod Configuration
RUNPOD_API_KEY=
RUNPOD_POD_ID=
RUNPOD_IDLE_TIMEOUT_S=300
